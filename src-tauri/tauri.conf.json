{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeshHop",
  "version": "0.3.2",
  "identifier": "com.meshhop.desktop",
  "build": {
    "beforeDevCommand": "npm run desktop:frontend:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run desktop:prepare",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MeshHop",
        "width": 880,
        "height": 720,
        "minWidth": 380,
        "minHeight": 580,
        "resizable": true,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "externalBin": ["binaries/meshhop-engine"],
    "resources": ["resources/uBlock0_1.72.2.firefox.signed.xpi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
