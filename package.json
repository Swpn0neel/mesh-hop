{
  "name": "meshhop",
  "version": "0.2.6",
  "description": "Tauri desktop app for automatic regional proxy discovery and browser routing",
  "private": true,
  "type": "module",
  "bin": {
    "meshhop-pair": "src/pair.js",
    "meshhop-coordinator": "src/coordinator.js",
    "meshhop-client": "src/client.js",
    "meshhop-exit": "src/exit.js"
  },
  "scripts": {
    "pair": "node src/pair.js",
    "coordinator": "node src/coordinator.js",
    "client": "node src/client.js",
    "exit": "node src/exit.js",
    "public": "node src/public.js",
    "public:check": "node src/public.js --check",
    "sidecar:build": "node scripts/build-sidecar.mjs",
    "browser-assets:verify": "node scripts/verify-browser-assets.mjs",
    "desktop:frontend": "vite build --config desktop-ui/vite.config.js",
    "desktop:prepare": "npm run desktop:frontend && npm run browser-assets:verify",
    "desktop:frontend:dev": "vite --config desktop-ui/vite.config.js",
    "desktop:dev": "npm run sidecar:build && tauri dev",
    "desktop:build": "npm run sidecar:build && tauri build",
    "desktop:build:debug": "npm run sidecar:build && tauri build --debug",
    "test": "node --test test/crypto.test.js test/net-policy.test.js test/coordinator.test.js test/public.test.js",
    "test:live": "node --test test/live.test.js",
    "test:public": "node --test test/public-live.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ipaddr.js": "^2.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "esbuild": "^0.28.1",
    "postject": "^1.0.0-alpha.6",
    "vite": "^8.1.4"
  }
}
