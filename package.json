{
  "name": "meshhop",
  "version": "0.4.0",
  "description": "Tauri desktop app for automatic regional proxy discovery and browser routing",
  "private": true,
  "type": "module",
  "scripts": {
    "public": "node src/public.js",
    "public:check": "node src/public.js --check",
    "sidecar:build": "node scripts/build-sidecar.mjs",
    "browser-assets:verify": "node scripts/verify-browser-assets.mjs",
    "desktop:frontend": "vite build --config desktop-ui/vite.config.js",
    "desktop:prepare": "npm run desktop:frontend && npm run browser-assets:verify",
    "desktop:frontend:dev": "vite --config desktop-ui/vite.config.js",
    "desktop:dev": "npm run sidecar:build && tauri dev",
    "desktop:bundle": "tauri build",
    "desktop:bundle:debug": "tauri build --debug",
    "desktop:build": "npm run sidecar:build && npm run desktop:bundle",
    "desktop:build:debug": "npm run sidecar:build && npm run desktop:bundle:debug",
    "release:stage": "node scripts/stage-release.mjs",
    "lint": "eslint .",
    "version:sync": "node scripts/sync-version.mjs",
    "version:check": "node scripts/sync-version.mjs --check",
    "test": "node --test test/env.test.js test/http-upgrade.test.js test/net-policy.test.js test/public.test.js test/socks-server.test.js test/throughput.test.js",
    "test:public": "node --test test/public-live.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ipaddr.js": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "postject": "^1.0.0-alpha.6",
    "vite": "^8.1.4"
  }
}
